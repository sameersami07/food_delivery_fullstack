# Gemini AI — auto-generate food descriptions in admin panel
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Google Maps — address autocomplete on checkout
# Enable "Places API" in Google Cloud Console
# Get key: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY="YOUR_GOOGLE_MAPS_API_KEY"

# Google Sign-In — "Continue with Google" on login
# Create OAuth 2.0 Client ID: https://console.cloud.google.com/apis/credentials/oauthclient
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"

# App URL (optional — used for OAuth callbacks in production)
APP_URL="http://localhost:3000"
